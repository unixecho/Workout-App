# Copy to .env.local and fill in once the Supabase project exists
# (see docs/TD.md — Deployment, and TODO.md for the open region decision).

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only — never expose to the client. Used by the small set of server
# actions that legitimately bypass RLS (docs/TD.md § Deployment).
SUPABASE_SERVICE_ROLE_KEY=

# Hardcoded auth-redirect origin (no trailing slash). Leave unset locally —
# falls back to window.location.origin so localhost keeps working. Must be
# set in Vercel's env vars to the real production domain, otherwise auth
# redirects fall back to whatever origin the request came from.
NEXT_PUBLIC_SITE_URL=
